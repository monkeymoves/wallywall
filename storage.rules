rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read, but only the owning user can write inside their own layout path.
    match /layouts/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Other files: authenticated read & write
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
